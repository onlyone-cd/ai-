ENVIRONMENT=production
APP_NAME=hireinsight
PORT=5001

# Frontend/API
VITE_API_BASE_URL=https://your-domain.example/api
CORS_ORIGINS=https://your-domain.example

# Security: replace every value before deployment.
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_NAME=系统管理员
# Optional: set only when running the one-time create-admin command, then remove from .env.
ADMIN_PASSWORD=replace-with-strong-admin-password
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
INTERVIEW_ROOM_TOKEN_HOURS=72
PUBLIC_INTERVIEW_MAX_REQUESTS_PER_MINUTE=60
PUBLIC_INTERVIEW_MAX_ANSWER_CHARS=4000
PUBLIC_INTERVIEW_MAX_MESSAGES=80
PUBLIC_INTERVIEW_MAX_CHEAT_EVENTS=100
SECURITY_HEADERS_ENABLED=true
TRUST_PROXY_COUNT=1
LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true
SLOW_REQUEST_MS=1000
TASK_WORKER_LIMIT=5
TASK_WORKER_SLEEP_SECONDS=5
AUDIT_LOG_RETENTION_DAYS=365
LLM_USAGE_RETENTION_DAYS=180
TASK_RETENTION_DAYS=90

# Database: use PostgreSQL/MySQL in production instead of SQLite.
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql+psycopg://hireinsight:replace-with-strong-postgres-password@postgres:5432/hireinsight
SEED_DEMO_DATA=false
AUTO_CREATE_DB=false

# Upload limits
UPLOAD_FOLDER=/data/uploads
BACKUP_FOLDER=/data/backups
MAX_CONTENT_LENGTH=16777216
MAX_UPLOAD_FILES=20
MAX_ARCHIVE_FILES=50
MAX_ARCHIVE_UNCOMPRESSED_SIZE=67108864
MAX_ARCHIVE_COMPRESSION_RATIO=100

# LLM
LLM_ENABLED=true
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_USAGE_LOG_ENABLED=true
LLM_PROMPT_PRICE_PER_1M_TOKENS_USD=0
LLM_COMPLETION_PRICE_PER_1M_TOKENS_USD=0
DEEPSEEK_API_KEY=replace-after-rotating-old-key

# Speech / AI interview
SPEECH_PROVIDER=browser
SPEECH_ASR_ENABLED=true
SPEECH_TTS_ENABLED=true
SPEECH_ASR_API_URL=
SPEECH_TTS_API_URL=
SPEECH_API_KEY=
SPEECH_MAX_AUDIO_BYTES=8388608
SPEECH_TTS_MAX_CHARS=1000
