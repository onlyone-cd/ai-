ENVIRONMENT=production
APP_NAME=hireinsight
PORT=5001
CORS_ORIGINS=https://your-domain.example
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_NAME=系统管理员
# Optional: set only when running the one-time create-admin command, then remove from .env.
ADMIN_PASSWORD=replace-with-strong-admin-password
DATABASE_URL=postgresql+psycopg://hireinsight:change-me@postgres:5432/hireinsight
SEED_DEMO_DATA=false
AUTO_CREATE_DB=false
UPLOAD_FOLDER=/data/uploads
MAX_CONTENT_LENGTH=16777216
MAX_UPLOAD_FILES=20
MAX_ARCHIVE_FILES=50
MAX_ARCHIVE_UNCOMPRESSED_SIZE=67108864
MAX_ARCHIVE_COMPRESSION_RATIO=100
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
SECURITY_HEADERS_ENABLED=true
TRUST_PROXY_COUNT=1
LOG_LEVEL=INFO
LLM_ENABLED=true
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_KEY=replace-after-rotating-old-key
