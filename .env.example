ENVIRONMENT=production
APP_NAME=hireinsight
PORT=5001

# Frontend/API
VITE_API_BASE_URL=https://your-domain.example/api
CORS_ORIGINS=https://your-domain.example

# Security: replace every value before deployment.
JWT_SECRET=replace-with-a-long-random-secret
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
SECURITY_HEADERS_ENABLED=true
TRUST_PROXY_COUNT=1

# Database: use PostgreSQL/MySQL in production instead of SQLite.
DATABASE_URL=postgresql+psycopg://hireinsight:change-me@postgres:5432/hireinsight
SEED_DEMO_DATA=false

# Upload limits
UPLOAD_FOLDER=/data/uploads
MAX_CONTENT_LENGTH=16777216
MAX_UPLOAD_FILES=20
MAX_ARCHIVE_FILES=50
MAX_ARCHIVE_UNCOMPRESSED_SIZE=67108864
MAX_ARCHIVE_COMPRESSION_RATIO=100

# LLM
LLM_ENABLED=true
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_KEY=replace-after-rotating-old-key
